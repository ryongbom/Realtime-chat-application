.env
.env.local
.env.production

# Log files - 로그는 로컬에서만
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files - 운영체제가 만드는 파일들
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories and files - 에디터 설정
.vscode/
.idea/
*.swp
*.swo
*~

# Dependency directories - 다른 패키지 매니저들
jspm_packages/

# Build outputs - 빌드 결과물
dist/
build/
*.tsbuildinfo

# Testing - 테스트 관련
coverage/
.nyc_output/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

